#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)

# Check for const redeclaration in JS/TS files only
STAGED_JS=$(echo "$STAGED" | grep -E '\.(js|ts|jsx|tsx)$' || true)
if [ -n "$STAGED_JS" ]; then
  for f in $STAGED_JS; do
    if [ -f "$f" ]; then
      CONST_VARS=$(grep -o 'const [a-zA-Z_][a-zA-Z0-9_]*' "$f" | sort | uniq -d)
      if [ -n "$CONST_VARS" ]; then
        echo "❌ const redeclared in $f:"
        echo "$CONST_VARS"
        exit 1
      fi
    fi
  done
fi

# Python files with embedded JS → use ESLint via lint-js.sh
STAGED_PY=$(echo "$STAGED" | grep -E '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
  HAS_JS=$(grep -l '<script>' $STAGED_PY 2>/dev/null || true)
  if [ -n "$HAS_JS" ]; then
    echo "🔍 Checking JS in Python files..."
    ./scripts/lint-js.sh $HAS_JS
  fi
fi

echo "✅ Pre-commit checks passed"
