#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Quick const redeclaration check on staged files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
  # Check for const vars that appear multiple times in the same file
  for f in $STAGED_PY; do
    if [ -f "$f" ]; then
      CONST_VARS=$(grep -o 'const [a-zA-Z_][a-zA-Z0-9_]*' "$f" | sort | uniq -d)
      if [ -n "$CONST_VARS" ]; then
        echo "❌ const redeclared in $f:"
        echo "$CONST_VARS"
        exit 1
      fi
    fi
  done

  # Check files with embedded JS using ESLint
  HAS_JS=$(grep -l '<script>' $STAGED_PY 2>/dev/null || true)
  if [ -n "$HAS_JS" ]; then
    echo "🔍 Checking JS in Python files..."
    ./scripts/lint-js.sh $HAS_JS
  fi
fi

echo "✅ Pre-commit checks passed"
